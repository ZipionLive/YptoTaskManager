@using Fluxor
@using Fluxor.Blazor.Web.Components
@using Microsoft.Extensions.Localization
@using YptoTaskManager.FE.Web.Services.Auth
@using YptoTaskManager.FE.Web.Dtos.Enums
@using YptoTaskManager.FE.Web.State.ActiveUser

@inherits FluxorComponent

@inject IAuthTokenProvider _authTokenProvider
@inject NavigationManager _nav
@inject IStringLocalizer<SharedResources> Loc
@inject IDispatcher _dispatcher
@inject IState<ActiveUserState> ActiveUserState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">YptoTaskManager.FE.Web</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill" width="32" height="32" aria-hidden="true"></i> @Loc["Home"]
            </NavLink>
        </div>
        @if (ActiveUserState.Value.User is null)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login" Match="NavLinkMatch.All">
                    <i class="bi bi-box-arrow-in-right" width="32" height="32" aria-hidden="true"></i> @Loc["Login"]
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" onclick="@(() => Logout())" Match="NavLinkMatch.All">
                    <i class="bi bi-box-arrow-right" width="32" height="32" aria-hidden="true"></i> @Loc["Logout"]
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/tasks" Match="NavLinkMatch.All">
                    <i class="bi bi-kanban" width="32" height="32" aria-hidden="true"></i> @Loc["Tasks"]
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/profile" Match="NavLinkMatch.All">
                    <i class="bi bi-person-circle" width="32" height="32" aria-hidden="true"></i> @Loc["Profile"]
                </NavLink>
            </div>
        }
        @if (ActiveUserState.Value.User?.Role == UserRole.Admin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/users" Match="NavLinkMatch.All">
                    <i class="bi bi-people-fill" width="32" height="32" aria-hidden="true"></i> Users
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private void Logout()
    {
        _authTokenProvider.ClearToken();
        _dispatcher.Dispatch(new ClearActiveUserAction());
        _nav.NavigateTo("/login", true);
    }
}