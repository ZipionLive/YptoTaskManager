@using Microsoft.Extensions.Localization

@inject IStringLocalizer<SharedResources> Loc

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h6 class="card-title">@Task.Name</h6>

        <div class="mb-2">
            <span class="badge text-bg-secondary">@Task.TaskTypeName</span>
            <span class="badge text-bg-info">@Task.TaskStatusName</span>
        </div>

        <div class="mb-2">
            <small class="text-muted">Assigned to:</small>

            @if (!AssignedUserNames.Any())
            {
                <span class="badge text-bg-light">None</span>
            }
            else
            {
                @foreach (var userName in AssignedUserNames)
                {
                    <span class="badge text-bg-primary me-1">@userName</span>
                }
            }
        </div>

        <small class="text-muted">
            @Loc["CreatedOn"] @Task.CreatedOn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        </small>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary"
                    @onclick="OnOpenClicked">
                @Loc["Open"]
            </button>
        </div>
    </div>
</div>